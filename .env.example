# ─────────────────────────────────────────────────────────────
# Automatic Restaurant OS — Environment Variables
# Copy this file to .env for local development.
# On Replit, set these as Secrets (never commit real values).
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Replit provisions this automatically. For local dev, set your
# own PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/automatic_db

# ── Session ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# ── GitHub Integration ────────────────────────────────────────
# Personal Access Token — github.com/settings/tokens
# Required scopes: repo, read:user, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Notion Integration ────────────────────────────────────────
# Internal Integration Token — notion.so/my-integrations
# Share your databases with the integration in the Notion UI.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# ── OpenAI Integration ────────────────────────────────────────
# API Key — platform.openai.com/api-keys
# Ensure your account has billing enabled.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
