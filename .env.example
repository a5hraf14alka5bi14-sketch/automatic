# ─────────────────────────────────────────────────────────────
# Automatic Restaurant OS — Environment Variables
# Copy this file to .env for local development.
# On Replit, set these as Secrets (never commit real values).
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Replit provisions this automatically. For local dev, set your
# own PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/automatic_db

# ── Session ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# ── GitHub Integration ────────────────────────────────────────
# Personal Access Token — github.com/settings/tokens
# Required scopes: repo, read:user, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Notion Integration ────────────────────────────────────────
# Internal Integration Token — notion.so/my-integrations
# Share your databases with the integration in the Notion UI.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# ── OpenAI Integration ────────────────────────────────────────
# API Key — platform.openai.com/api-keys
# Ensure your account has billing enabled.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Public deployment URL (used for canonical + OG/Twitter metadata) ─────
# Set to your production root URL (no trailing slash) so Vite substitutes
# %VITE_APP_URL% in index.html with the real origin at build time.
# Leave unset for local dev — the %VITE_APP_URL% placeholder will remain
# literal, which is fine for development but must be set before publishing.
# Example: VITE_APP_URL=https://your-app.replit.app
# VITE_APP_URL=

# ── Native app backend URL (Capacitor / Electron builds only) ─────
# The web app is served same-origin as the API, so leave this UNSET for
# web/dev — API calls stay relative. Native shells (iOS/Android via
# Capacitor, Windows via Electron) load bundled assets from
# capacitor://localhost / file://, so they must point at the DEPLOYED
# backend origin (no trailing slash). Baked in at build time by Vite.
# Example: VITE_API_BASE_URL=https://your-app.replit.app
# VITE_API_BASE_URL=
