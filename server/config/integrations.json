{
  "version": "1.0.0",
  "services": {
    "notion": {
      "enabled": true,
      "label": "Notion",
      "description": "مزامنة المشاريع والمهام مع Notion",
      "env_key": "NOTION_API_KEY",
      "settings_keys": ["notion_api_key", "notion_projects_db", "notion_tasks_db"],
      "auto_sync": {
        "enabled": false,
        "interval_minutes": 15,
        "min_interval_minutes": 5,
        "max_interval_minutes": 1440
      },
      "databases": {
        "projects": {
          "key": "notion_projects_db",
          "label": "قاعدة المشاريع",
          "default_id": "bea6bf0f-16f9-455c-b887-dee7b7cba587"
        },
        "tasks": {
          "key": "notion_tasks_db",
          "label": "قاعدة المهام",
          "default_id": "2ea23851-9271-456c-bad7-cfa25fa2683d"
        }
      },
      "field_map": {
        "project_title_field": "Project",
        "task_title_field": "Task",
        "status_field": "Status",
        "priority_field": "Priority",
        "due_date_field": "Due Date",
        "start_date_field": "Start Date",
        "project_relation_field": "Project"
      }
    },
    "github": {
      "enabled": true,
      "label": "GitHub",
      "description": "مزامنة المستودعات مع GitHub",
      "env_key": "GITHUB_TOKEN",
      "settings_keys": ["github_token"],
      "auto_sync": {
        "enabled": false,
        "interval_minutes": 60
      }
    },
    "openai": {
      "enabled": true,
      "label": "OpenAI",
      "description": "ميزات الذكاء الاصطناعي",
      "env_key": "OPENAI_API_KEY",
      "settings_keys": ["openai_api_key"]
    }
  },
  "github_notion_link": {
    "enabled": true,
    "description": "ربط مستودعات GitHub بمشاريع Notion"
  }
}
