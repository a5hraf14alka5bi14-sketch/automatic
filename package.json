{
  "name": "automatic-restaurant-os",
  "version": "0.13.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "Smart Restaurant Management System",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "vite --host 0.0.0.0 --port 5000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run tests/",
    "test:coverage": "vitest run tests/ --coverage",
    "db:setup": "node scripts/init-db.js",
    "backup": "bash scripts/backup.sh",
    "release:set-version": "node scripts/set-version.js",
    "release:sync-log": "node scripts/sync-release-log.js",
    "check:version": "node scripts/check-version-sync.js",
    "scan:secrets": "node scripts/scan-secrets.js --all",
    "scan:secrets:history": "node scripts/scan-secrets.js --history",
    "cap:sync": "npm run build && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run build && electron-builder --win --config electron-builder.json",
    "postinstall": "bash scripts/install-git-hooks.sh || true",
    "electron:smoke": "node scripts/electron-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium --with-deps"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^7.5.0",
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/push-notifications": "^7.0.7",
    "@capacitor/splash-screen": "^7.0.5",
    "@notionhq/client": "^5.22.0",
    "@sentry/node": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express-session": "^1.19.0",
    "@types/memoizee": "^0.4.12",
    "@types/multer": "^2.2.0",
    "@types/passport": "^1.0.17",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "hash-wasm": "^4.12.0",
    "helmet": "^8.2.0",
    "joi": "^18.2.3",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "memoizee": "^0.4.17",
    "multer": "^2.2.0",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "pg": "^8.22.0",
    "playwright-core": "^1.61.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "speakeasy": "^2.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^8.2.2",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9",
    "postcss": "^8.5.15",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
