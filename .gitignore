# Dependencies
node_modules/
.npm

# Build output
dist/
build/
.vite/

# Environment variables — never commit real secrets
.env
.env.local
.env.*.local
.env.production

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# Replit internals (keep .replit for config, ignore caches)
.cache/
.upm/
.local/state/

# TypeScript cache
*.tsbuildinfo

# Local DB backups
backups/

# Test coverage output
coverage/

# ── Native app build artifacts ────────────────────────────────
# The Capacitor android/ + ios/ source projects ARE committed, but their
# generated build outputs and fetched native deps are not.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/release/
android/capacitor-cordova-android-plugins/
ios/App/Pods/
ios/App/build/
ios/App/output/
ios/App/App/public/
DerivedData/

# Electron packaged installers
release/
.replit_integration_files/

# Working files (screenshots, pasted text, quotes/menus) — never belonged in version control
attached_assets/
